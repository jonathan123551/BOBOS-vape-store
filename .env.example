# =============================================================================
# BOBOS Vapes Store — environment variables
# =============================================================================
# Every variable below has a safe default in code, so the project boots out of
# the box (great for Lovable / Replit imports). For production deploys, override
# them via your host's secret manager (Vercel, Netlify, Render, Fly, etc.).
# =============================================================================

# --- Database ----------------------------------------------------------------
# Default: SQLite — zero-config, perfect for Lovable/Replit/local dev.
# IMPORTANT: keep the path relative to the project root (`./dev.db`), NOT
# `./prisma/dev.db`, because Prisma resolves it from the CWD.
# For production on Vercel/Netlify use a hosted Postgres (Neon, Supabase, etc):
#   DATABASE_URL="postgresql://USER:PASS@HOST:5432/DB?sslmode=require"
# (then change provider to "postgresql" in prisma/schema.prisma).
DATABASE_URL="file:./dev.db"

# --- Admin credentials -------------------------------------------------------
# This app has exactly ONE admin account. There is no public registration UI
# and no /api/admin/register endpoint. The credentials below are the defaults;
# override them in production with a strong password.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="bobos-admin-2026"

# Random string used to HMAC-sign the admin auth cookie.
# Generate a fresh one with:  openssl rand -hex 32
ADMIN_SECRET="bobos-default-dev-secret-please-change-in-production"

# --- Public site config ------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_PHONE="01287566246"
NEXT_PUBLIC_WHATSAPP_LINK="https://chat.whatsapp.com/Es1cmi0a7Mp8Qz4PtyiDgF?mode=hqctcli"

# --- Optional: Cloudinary image hosting --------------------------------------
# If left blank, uploads fall back to local disk in /public/uploads.
# (Local uploads do NOT persist on serverless hosts like Vercel — set these
# four for any production deploy that needs admin image uploads to survive.)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET=""
