# --- Supabase ---------------------------------------------------------------
# Get these from https://supabase.com/dashboard → your project → Settings → API.
# Both are SAFE to expose in client code (anon key is what's used on the
# storefront, RLS policies enforce access).
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR-ANON-PUBLIC-KEY"

# When VITE_SUPABASE_URL is unset/empty, the storefront falls back to a static
# seed (src/lib/seed.ts). Useful for previewing on Lovable before wiring up
# Supabase, or for offline demos.

# --- Storefront branding (optional) -----------------------------------------
VITE_STORE_PHONE="01287566246"
VITE_WHATSAPP_LINK="https://chat.whatsapp.com/Es1cmi0a7Mp8Qz4PtyiDgF?mode=hqctcli"
