# --- Database -----------------------------------------------------------------
# Postgres connection string. For local dev use a free Neon (https://neon.tech)
# or Supabase database — same URL works in dev and prod.
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/bobos?sslmode=require"

# --- Admin credentials --------------------------------------------------------
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="bobos-admin-2026"
# Random string used to sign the admin auth cookie. Generate with: openssl rand -hex 32
ADMIN_SECRET="change-me-to-a-long-random-string-please"

# --- Site ---------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_PHONE="01287566246"
NEXT_PUBLIC_WHATSAPP_LINK="https://chat.whatsapp.com/Es1cmi0a7Mp8Qz4PtyiDgF?mode=hqctcli"

# --- Cloudinary (REQUIRED on Vercel — local /public/uploads is read-only there) ---
# Locally these can be blank and uploads fall back to /public/uploads.
# On Vercel you MUST set CLOUDINARY_CLOUD_NAME + CLOUDINARY_UPLOAD_PRESET (unsigned)
# or image upload from the admin panel will return 503.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET=""
